            done
        elif [[ $stage == benchmark ]]; then
            printf '%s\n' benchmark-single-warmup >> "$RUN_DIR/expected-stages"
            for ((run = 1; run <= BENCHMARK_RUNS; run++)); do
                printf 'benchmark-single-run-%s\n' "$run" >> "$RUN_DIR/expected-stages"
            done
            printf '%s\n' benchmark-multi-warmup >> "$RUN_DIR/expected-stages"
            for ((run = 1; run <= BENCHMARK_RUNS; run++)); do
                printf 'benchmark-multi-run-%s\n' "$run" >> "$RUN_DIR/expected-stages"
            done
            printf '%s\n' benchmark-summary >> "$RUN_DIR/expected-stages"
        else
            printf '%s\n' "$stage" >> "$RUN_DIR/expected-stages"
        fi
    done
}

extract_benchmark_metrics() {
    local log=$1
    local label=$2
    local scope
    local run
    local temporary="$RUN_DIR/.benchmark-metrics.tmp"

    case $label in
        benchmark-single-run-*) scope=single ;;
        benchmark-multi-run-*) scope=multi ;;
        *) return 0 ;;
    esac
    run=${label##*-}
    [[ $run =~ ^[1-9][0-9]*$ && -r $log ]] || return 1

    LC_ALL=C awk -v scope="$scope" -v run="$run" '
        {
            for (i = 2; i < NF; i++) {
                value = $(i - 1)
                if ($(i + 1) == "Mfp-ops/sec" &&
                    value ~ /^[0-9]+([.][0-9]+)?([eE][+-]?[0-9]+)?$/ &&
                    value + 0 > 0) {
                    metric = $i " " $(i + 1)
                    if (seen[metric]++) duplicate = 1
                    else printf "%s\t%s\t%s\t%s\n", scope, run, metric, value
                    found = 1
                }
            }
        }
        END { if (!found || duplicate) exit 1 }
    ' "$log" > "$temporary" || {
        rm -f -- "$temporary"
        return 1
    }
    cat "$temporary" >> "$RUN_DIR/benchmark.tsv"
    rm -f -- "$temporary"
}

extract_benchmark_frequencies() {
    local log=$1
    local label=$2
    local scope
    local run
    local expected_cpu_list
    local cpu
    local package
    local core
    local topology_values=""
    local -a expected_cpus=()
    local temporary="$RUN_DIR/.benchmark-frequencies.tmp"
    local IFS=,

    case $label in
        benchmark-single-run-*)
            scope=single
            expected_cpu_list=${CPUS[0]}
            ;;
        benchmark-multi-run-*)
            scope=multi
            expected_cpu_list=$BENCHMARK_CPU_LIST
            ;;
        *) return 0 ;;
    esac
    run=${label##*-}
    [[ $run =~ ^[1-9][0-9]*$ && -r $log && -n $expected_cpu_list ]] || return 1
    read -r -a expected_cpus <<< "$expected_cpu_list"
    ((${#expected_cpus[@]} > 0)) || return 1
    for cpu in "${expected_cpus[@]}"; do
        [[ $cpu =~ ^[0-9]+$ ]] || return 1
        IFS= read -r package < "$SYS_CPU_ROOT/cpu${cpu}/topology/physical_package_id" ||
            return 1
        IFS= read -r core < "$SYS_CPU_ROOT/cpu${cpu}/topology/core_id" || return 1
        [[ $package =~ ^[0-9]+$ && $core =~ ^[0-9]+$ ]] || return 1
        topology_values+="${cpu}:${package}:${core},"
    done

    LC_ALL=C awk -v scope="$scope" -v run="$run" -v label="$label" \
        -v expected_cpu_list="$expected_cpu_list" -v topology_values="$topology_values" '
        BEGIN {
            FS = "[ \t]+"
            OFS = "\t"
            split(expected_cpu_list, cpu_values, ",")
            for (i in cpu_values) expected[cpu_values[i]] = 1
            topology_count = split(topology_values, topology_entries, ",")
            for (i = 1; i < topology_count; i++) {
                split(topology_entries[i], topology, ":")
                topology_package[topology[1]] = topology[2]
                topology_core[topology[1]] = topology[3]
            }
        }
        $1 == "STRESS_UV_FREQUENCY_BEGIN" {
            if (inside || begin_seen++ || NF != 2 || $2 != label) invalid = 1
            inside = 1
            next
        }
        $1 == "STRESS_UV_FREQUENCY_END" {
            if (!inside || end_seen++ || NF != 2 || $2 != label) invalid = 1
            inside = 0
            next
        }
        !inside { next }
        {
            if ($0 == "") next
            if ($1 == "Time_Of_Day_Seconds") {
                for (i = 1; i <= NF; i++) column[$i] = i
                if (!("Time_Of_Day_Seconds" in column) || !("CPU" in column) ||
                    !("Avg_MHz" in column) || !("Busy%" in column) ||
                    !("Bzy_MHz" in column)) invalid = 1
                header_seen = 1
                next
            }
            if (!header_seen) {
                invalid = 1
                next
            }
            cpu = $(column["CPU"])
            if (cpu == "-") next
            time = $(column["Time_Of_Day_Seconds"])
            avg = $(column["Avg_MHz"])
            busy = $(column["Busy%"])
            bzy = $(column["Bzy_MHz"])
            if (cpu !~ /^[0-9]+$/ || time !~ /^[0-9]+([.][0-9]+)?$/ ||
                avg !~ /^[0-9]+([.][0-9]+)?$/ ||
                busy !~ /^[0-9]+([.][0-9]+)?$/ || bzy !~ /^[0-9]+([.][0-9]+)?$/ ||
                !(cpu in expected) || !(cpu in topology_package) ||
                !(cpu in topology_core) || avg + 0 <= 0 || bzy + 0 <= 0 ||
                busy + 0 < 0 || busy + 0 > 100 || seen_time[cpu, time]++) {
                invalid = 1
                next
            }
            sample = ++count[cpu]
            times[cpu, sample] = time
            averages[cpu, sample] = avg
            busies[cpu, sample] = busy
            bzys[cpu, sample] = bzy
            actual[cpu] = 1
        }
        END {
            if (inside || begin_seen != 1 || end_seen != 1 || !header_seen) invalid = 1
            reference_count = 0
            for (cpu in expected) {
                if (!(cpu in actual) || count[cpu] < 5) invalid = 1
                if (!reference_count) reference_count = count[cpu]
                else if (count[cpu] != reference_count) invalid = 1
            }
            for (cpu in actual) if (!(cpu in expected)) invalid = 1
            if (invalid) exit 1
            for (cpu in expected) {
                for (sample = 2; sample < count[cpu]; sample++) {
                    print scope, run, sample, times[cpu, sample], topology_package[cpu],
                        topology_core[cpu], cpu, averages[cpu, sample],
                        busies[cpu, sample], bzys[cpu, sample]
                }
            }
        }
    ' "$log" > "$temporary" || {
        rm -f -- "$temporary"
        return 1
    }
    [[ -s $temporary ]] || { rm -f -- "$temporary"; return 1; }
    sort -t $'\t' -k7,7n -k3,3n "$temporary" >> "$RUN_DIR/benchmark-frequencies.tsv"
    rm -f -- "$temporary"
}

write_benchmark_frequency_summary() {
    local unsorted="$RUN_DIR/.benchmark-frequency-summary.tmp"

    [[ -s $RUN_DIR/benchmark-frequencies.tsv ]] || return 1
    LC_ALL=C awk -F '\t' -v expected_runs="$BENCHMARK_RUNS" '
        function numeric(value) {
            return value ~ /^[0-9]+([.][0-9]+)?$/
        }
        function nearest_rank(count, percentile, rank) {
            rank = int(count * percentile)
            if (rank < count * percentile) rank++
            return rank < 1 ? 1 : rank
        }
        NR == 1 {
            if ($0 != "scope\trun\tsample\ttime_seconds\tpackage\tcore\tcpu\tavg_mhz\tbusy_percent\tbzy_mhz") invalid = 1
            next
        }
        {
            key = $1 SUBSEP $5 SUBSEP $6 SUBSEP $7
            run_key = key SUBSEP $2
            if (NF != 10 || ($1 != "single" && $1 != "multi") ||
                $2 !~ /^[1-9][0-9]*$/ || $2 + 0 > expected_runs ||
                $3 !~ /^[0-9]+$/ || $3 + 0 < 2 ||
                !numeric($4) || $5 !~ /^[0-9]+$/ || $6 !~ /^[0-9]+$/ ||
                $7 !~ /^[0-9]+$/ || !numeric($8) || !numeric($9) ||
                !numeric($10) || $8 + 0 <= 0 || $9 + 0 < 0 ||
                $9 + 0 > 100 || $10 + 0 <= 0 || seen[key, $2, $3]++) {
                invalid = 1
                next
            }
            scopes[key] = $1
            packages[key] = $5
            cores[key] = $6
            cpus[key] = $7
            averages[key, ++count[key]] = $8 + 0
            busies[key, count[key]] = $9 + 0
            bzys[key, count[key]] = $10 + 0
            run_samples[run_key]++
            if (!(key in keys)) key_count++
            keys[key] = 1
        }
        END {
            for (key in keys) {
                for (run = 1; run <= expected_runs; run++) {
                    if (run_samples[key SUBSEP run] < 3) invalid = 1
                }
            }
            if (invalid || key_count == 0) exit 1
            for (key in keys) {
                n = count[key]
                for (i = 2; i <= n; i++) {
                    avg = averages[key, i]
                    busy = busies[key, i]
                    bzy = bzys[key, i]
                    j = i - 1
                    while (j >= 1 && bzys[key, j] > bzy) {
                        bzys[key, j + 1] = bzys[key, j]
                        j--
                    }
                    bzys[key, j + 1] = bzy
                    j = i - 1
                    while (j >= 1 && averages[key, j] > avg) {
                        averages[key, j + 1] = averages[key, j]
                        j--
                    }
                    averages[key, j + 1] = avg
                    j = i - 1
                    while (j >= 1 && busies[key, j] > busy) {
                        busies[key, j + 1] = busies[key, j]
                        j--
                    }
                    busies[key, j + 1] = busy
                }
                if (n % 2) {
                    median_bzy = bzys[key, (n + 1) / 2]
                    median_avg = averages[key, (n + 1) / 2]
                    median_busy = busies[key, (n + 1) / 2]
                } else {
                    median_bzy = (bzys[key, n / 2] + bzys[key, n / 2 + 1]) / 2
                    median_avg = (averages[key, n / 2] + averages[key, n / 2 + 1]) / 2
                    median_busy = (busies[key, n / 2] + busies[key, n / 2 + 1]) / 2
                }
                p05 = bzys[key, nearest_rank(n, 0.05)]
                p95 = bzys[key, nearest_rank(n, 0.95)]
                printf "%s\t%s\t%s\t%s\t%.3f\t%.3f\t%.3f\t%.3f\t%.3f\t%d\n", \
                    scopes[key], packages[key], cores[key], cpus[key], median_bzy,
                    p05, p95, median_avg, median_busy, n
            }
        }
    ' "$RUN_DIR/benchmark-frequencies.tsv" > "$unsorted" || {
        rm -f -- "$unsorted" "$RUN_DIR/benchmark-frequency-summary.tsv"
        return 1
    }
    {
        printf 'scope\tpackage\tcore\tcpu\tmedian_bzy_mhz\tp05_bzy_mhz\tp95_bzy_mhz\tmedian_avg_mhz\tmedian_busy_percent\tsample_count\n'
        sort -t $'\t' -k1,1 -k2,2n -k3,3n -k4,4n "$unsorted"
    } > "$RUN_DIR/benchmark-frequency-summary.tsv"
    rm -f -- "$unsorted"
}

cpu_config_value() {
    local file=$1
    local type=$2
    local value

    [[ $type == text || $type == integer ]] || return 1
    if [[ ! -e $file ]]; then
        printf 'unavailable\n'
        return
    fi
    [[ -r $file ]] || return 1
    IFS= read -r value < "$file" || [[ -n $value ]] || return 1
    [[ -n $value && $value != *$'\t'* ]] || return 1
    [[ $type == text || $value =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "$value"
}

write_benchmark_cpu_config() {
    local cpu
    local cpu_path
    local policy_path
    local policy
    local driver
    local governor
    local scaling_min
    local scaling_max
    local cpuinfo_min
    local cpuinfo_max
    local boost
    local no_turbo
    local -a benchmark_cpus=()

    IFS=, read -r -a benchmark_cpus <<< "$BENCHMARK_CPU_LIST"
    ((${#benchmark_cpus[@]} > 0)) || return 1
    boost=$(cpu_config_value "$SYS_CPU_ROOT/cpufreq/boost" integer) || return 1
    no_turbo=$(cpu_config_value "$SYS_CPU_ROOT/intel_pstate/no_turbo" integer) || return 1
    printf 'cpu\tpolicy\tscaling_driver\tscaling_governor\tscaling_min_khz\tscaling_max_khz\tcpuinfo_min_khz\tcpuinfo_max_khz\tboost\tno_turbo\n' > "$RUN_DIR/benchmark-cpu-config.tsv"
    for cpu in "${benchmark_cpus[@]}"; do
        [[ $cpu =~ ^[0-9]+$ ]] || return 1
        cpu_path="$SYS_CPU_ROOT/cpu${cpu}/cpufreq"
        if [[ -e $cpu_path ]]; then
            policy_path=$(readlink -f -- "$cpu_path") || return 1
            [[ -d $policy_path ]] || return 1
            policy=${policy_path##*/}
        else
            policy_path=$cpu_path
            policy=unavailable
        fi
        driver=$(cpu_config_value "$policy_path/scaling_driver" text) || return 1
        governor=$(cpu_config_value "$policy_path/scaling_governor" text) || return 1
        scaling_min=$(cpu_config_value "$policy_path/scaling_min_freq" integer) || return 1
        scaling_max=$(cpu_config_value "$policy_path/scaling_max_freq" integer) || return 1
        cpuinfo_min=$(cpu_config_value "$policy_path/cpuinfo_min_freq" integer) || return 1
        cpuinfo_max=$(cpu_config_value "$policy_path/cpuinfo_max_freq" integer) || return 1
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$cpu" "$policy" "$driver" "$governor" "$scaling_min" \
            "$scaling_max" "$cpuinfo_min" "$cpuinfo_max" "$boost" "$no_turbo" \
            >> "$RUN_DIR/benchmark-cpu-config.tsv"
    done
}

write_benchmark_summary() {
    local unsorted="$RUN_DIR/.benchmark-summary.tmp"

    [[ -s $RUN_DIR/benchmark.tsv ]] || return 1
    LC_ALL=C awk -F '\t' -v expected_runs="$BENCHMARK_RUNS" '
        NR == 1 { next }
        NF == 4 {
            key = $1 SUBSEP $3
            scope[key] = $1
            metric[key] = $3
            values[key, ++count[key]] = $4 + 0
            sum[key] += $4
        }
        END {
            for (key in count) {
                if (!(metric[key] in metric_names)) metric_count++
                metric_names[metric[key]] = 1
                present[scope[key], metric[key]] = 1
                if (count[key] != expected_runs) invalid = 1
            }
            for (name in metric_names) {
                if (!(present["single", name]) || !(present["multi", name])) invalid = 1
            }
            if (invalid || metric_count == 0) exit 1
            for (key in count) {
                n = count[key]
                for (i = 2; i <= n; i++) {
                    value = values[key, i]
                    j = i - 1
                    while (j >= 1 && values[key, j] > value) {
                        values[key, j + 1] = values[key, j]
                        j--
                    }
                    values[key, j + 1] = value
                }
                if (n % 2) median = values[key, (n + 1) / 2]
                else median = (values[key, n / 2] + values[key, n / 2 + 1]) / 2
                mean = sum[key] / n
                variance = 0
                for (i = 1; i <= n; i++) variance += (values[key, i] - mean) ^ 2
                variance /= n
                cv = mean > 0 ? sqrt(variance) / mean * 100 : 0
                printf "%s\t%s\t%.3f\t%.3f\t%.3f\t%.3f\n", \
                    scope[key], metric[key], median, values[key, 1], values[key, n], cv
            }
        }
    ' "$RUN_DIR/benchmark.tsv" > "$unsorted" || {
        rm -f -- "$unsorted" "$RUN_DIR/benchmark-summary.tsv"
        return 1
    }
    {
        printf 'scope\tmetric\tmedian_mfp_ops_per_sec\tmin\tmax\tcv_percent\n'
        sort -t $'\t' -k1,1 -k2,2 "$unsorted"
    } > "$RUN_DIR/benchmark-summary.tsv"
    rm -f -- "$unsorted"
}

start_file_telemetry() {
    if command_exists sensors; then
        sensors > "$RUN_DIR/telemetry/sensors-before.txt" 2>&1 || true
    fi
}

stop_file_telemetry() {
    if command_exists sensors; then
        sensors > "$RUN_DIR/telemetry/sensors-after.txt" 2>&1 || true
    fi
}

process_is_running() {
    local pid=$1
    local stat
    local stat_tail
    local state

    if [[ -r $PROC_ROOT/$pid/stat ]]; then
        stat=$(< "$PROC_ROOT/$pid/stat")
        stat_tail=${stat##*) }
        state=${stat_tail%% *}
        [[ $state != Z ]]
        return
    fi
    kill -0 "$pid" 2>/dev/null
}

process_starttime() {
    local pid=$1
    local stat
    local stat_tail
    local fields=()

    [[ -r $PROC_ROOT/$pid/stat ]] || return 1
    stat=$(< "$PROC_ROOT/$pid/stat")
    stat_tail=${stat##*) }
    read -r -a fields <<< "$stat_tail"
    ((${#fields[@]} >= 20)) || return 1
    [[ ${fields[19]} =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "${fields[19]}"
}

process_matches_identity() {
    local pid=$1
    local expected_starttime=$2
    local stat
    local stat_tail
    local fields=()

    [[ -r $PROC_ROOT/$pid/stat ]] || return 1
    stat=$(< "$PROC_ROOT/$pid/stat")
    stat_tail=${stat##*) }
    read -r -a fields <<< "$stat_tail"
    ((${#fields[@]} >= 20)) || return 1
    [[ ${fields[0]} != Z && ${fields[19]} == "$expected_starttime" ]]
}

authenticate_sudo() {
    if [[ -n ${SUDO_ASKPASS:-} && -x ${SUDO_ASKPASS:-} ]]; then
        printf 'Requesting administrator authentication with SUDO_ASKPASS.\n'
        sudo -A -v || {
            printf 'Graphical authentication failed; falling back to the terminal.\n'
            sudo -v || return 1
        }
    else
        printf 'Administrator authentication is required once for this run.\n'
        sudo -v || return 1
    fi
}

close_broker_fds() {
    if [[ $BROKER_IN_FD =~ ^[0-9]+$ ]]; then
        exec {BROKER_IN_FD}>&-
    fi
    if [[ $BROKER_OUT_FD =~ ^[0-9]+$ ]]; then
        exec {BROKER_OUT_FD}<&-
    fi
    BROKER_IN_FD=""
    BROKER_OUT_FD=""
    if [[ -n $BROKER_REQUEST_PATH ]]; then
        rm -f -- "$BROKER_REQUEST_PATH"
        BROKER_REQUEST_PATH=""
    fi
}

broker_wrapper_is_running() {
    [[ $BROKER_PID =~ ^[1-9][0-9]*$ && $BROKER_STARTTIME =~ ^[0-9]+$ ]] || return 1
    process_matches_identity "$BROKER_PID" "$BROKER_STARTTIME"
}

start_privileged_broker() {
    local response
    local version
    local coproc_input_fd
    local broker_bash
    local broker_bash_metadata
    local broker_bash_owner
    local broker_bash_mode
    local worker_starttime

    authenticate_sudo || return 1
    broker_bash=$(readlink -f -- "${BASH:-/bin/bash}") || return 1
    [[ -x $broker_bash && ! -L $broker_bash ]] || return 1
    broker_bash_metadata=$(stat -c '%u %a' -- "$broker_bash") || return 1
    read -r broker_bash_owner broker_bash_mode <<< "$broker_bash_metadata"
    [[ $broker_bash_owner == 0 && $broker_bash_mode =~ ^[0-7]+$ ]] || return 1
    (( (8#$broker_bash_mode & 0022) == 0 )) || return 1
    worker_starttime=$(process_starttime "$$") || return 1
    BROKER_REQUEST_PATH="$RUN_DIR/.broker-requests"
    rm -f -- "$BROKER_REQUEST_PATH"
    mkfifo -m 600 -- "$BROKER_REQUEST_PATH" || return 1
    coproc STRESS_UV_BROKER_PROCESS {
        sudo -n -- "$broker_bash" "$SCRIPT_PATH" __broker \
            "$MODE" "$CPU_DURATION" "$CORE_DURATION" "$CACHE_DURATION" \
            "$VM_DURATION" "$MEMORY_PERCENT" "$REFRESH_RATE" "$CPU_LIST" \
            "$BENCHMARK_CPU_LIST" "$STARTED_AT" "$BENCHMARK_DURATION" "$BENCHMARK_WARMUP" \
            "$BENCHMARK_RUNS" "$$" "$worker_starttime" \
            "$(id -u)" "$BROKER_REQUEST_PATH" "$STRESSAPPTEST_DURATION" \
            "$MEMTESTER_LOOPS"
    } 2>> "$RUN_DIR/broker-errors.txt"
    BROKER_PID=$STRESS_UV_BROKER_PROCESS_PID
    BROKER_STARTTIME=$(process_starttime "$BROKER_PID" 2>/dev/null || true)
    BROKER_OUT_FD=${STRESS_UV_BROKER_PROCESS[0]}
    coproc_input_fd=${STRESS_UV_BROKER_PROCESS[1]}
    exec {coproc_input_fd}>&-

    if [[ ! $BROKER_STARTTIME =~ ^[0-9]+$ ]] ||
        ! IFS=$'\t' read -r -t 15 -u "$BROKER_OUT_FD" response version ||
        [[ $response != READY || $version != 1 ]]; then
        printf 'stress-uv: privileged broker failed to start\n' >&2
        close_broker_fds
        broker_wrapper_is_running && kill -TERM "$BROKER_PID" 2>/dev/null || true
        wait "$BROKER_PID" 2>/dev/null || true
        BROKER_PID=""
        BROKER_STARTTIME=""
        return 1
    fi
    exec {BROKER_IN_FD}> "$BROKER_REQUEST_PATH" || return 1
    if [[ -n $TUI_PANE ]]; then
        tmux select-pane -t "$TUI_PANE" 2>/dev/null || true
    fi
}

send_broker_request() {
    [[ $BROKER_IN_FD =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "$1" 2>/dev/null >&"$BROKER_IN_FD"
}

receive_stage_from_broker() {
    local log=$1
    local encoded="$log.b64"
    local type
    local field
    local payload
    local decoded=0
    local read_status
    local temporary="$log.partial.$$"

    rm -f -- "$log" "$temporary"
    : > "$encoded"
    while :; do
        if IFS=$'\t' read -r -t 1 -u "$BROKER_OUT_FD" type field payload 2>/dev/null; then
            read_status=0
        else
            read_status=$?
            (( read_status > 128 )) && continue
            rm -f -- "$encoded" "$temporary" "$log"
            return 125
        fi
        case $type in
            DATA_BEGIN)
                [[ $field == stage ]] || { rm -f -- "$encoded" "$temporary" "$log"; return 125; }
                : > "$encoded"
                ;;
            DATA)
                [[ $field == stage && -n ${payload:-} ]] || { rm -f -- "$encoded" "$temporary" "$log"; return 125; }
                printf '%s\n' "$payload" >> "$encoded"
                ;;
            DATA_END)
                [[ $field == stage ]] || { rm -f -- "$encoded" "$temporary" "$log"; return 125; }
                if ! base64 -d -- "$encoded" > "$temporary"; then
                    rm -f -- "$encoded" "$temporary" "$log"
                    return 125
                fi
                decoded=1
                ;;
            DONE)
                [[ $field =~ ^[0-9]+$ && $decoded == 1 ]] || { rm -f -- "$encoded" "$temporary" "$log"; return 125; }
                mv -f -- "$temporary" "$log" || { rm -f -- "$encoded" "$temporary" "$log"; return 125; }
                rm -f -- "$encoded"
                return "$field"
                ;;
            ERROR)
                printf 'stress-uv: privileged broker: %s\n' "$field" >&2
                rm -f -- "$encoded" "$temporary" "$log"
                return 125
                ;;
            *)
                rm -f -- "$encoded" "$temporary" "$log"
                return 125
                ;;
        esac
    done
}

telemetry_path_for_source() {
    case $1 in
        turbostat) printf '%s\n' "$RUN_DIR/telemetry/turbostat.txt" ;;
        turbostat-errors) printf '%s\n' "$RUN_DIR/telemetry/turbostat-errors.txt" ;;
        turbostat-unavailable) printf '%s\n' "$RUN_DIR/telemetry/turbostat-unavailable.txt" ;;
        kernel) printf '%s\n' "$RUN_DIR/kernel.log" ;;
        kernel-errors) printf '%s\n' "$RUN_DIR/kernel-errors.txt" ;;
        journal-unavailable) printf '%s\n' "$RUN_DIR/kernel-errors.txt" ;;
        *) return 1 ;;
    esac
}

collect_broker_telemetry() {
    local type
    local source
    local payload
    local read_status
    local target=""
    local encoded=""
    local temporary=""
    local index
    local -a pending_targets=()
    local -a pending_temporaries=()
    local -A seen_sources=()

    send_broker_request COLLECT || return 1
    while :; do
        if IFS=$'\t' read -r -t 2 -u "$BROKER_OUT_FD" type source payload 2>/dev/null; then
            read_status=0
        else
            read_status=$?
            (( read_status > 128 )) && continue
            rm -f -- "${pending_temporaries[@]}" "$temporary" "$encoded"
            return 1
        fi
        case $type in
            DATA_BEGIN)
                target=$(telemetry_path_for_source "$source") || return 1
                [[ -z ${seen_sources[$source]:-} ]] || return 1
                seen_sources[$source]=1
                encoded="$target.b64"
                temporary="$target.partial.$$"
                rm -f -- "$target" "$temporary"
                : > "$encoded"
                ;;
            DATA)
                [[ -n $encoded && -n ${payload:-} ]] || return 1
                printf '%s\n' "$payload" >> "$encoded"
                ;;
            DATA_END)
                [[ -n $encoded && $target == "$(telemetry_path_for_source "$source")" ]] || return 1
                if ! base64 -d -- "$encoded" > "$temporary"; then
                    rm -f -- "${pending_temporaries[@]}" "$temporary" "$encoded"
                    return 1
                fi
                pending_targets+=("$target")
                pending_temporaries+=("$temporary")
                rm -f -- "$encoded"
                target=""
                encoded=""
                temporary=""
                ;;
            COLLECTED)
                [[ $source == 0 && -z $encoded ]] || return 1
                for ((index = 0; index < ${#pending_targets[@]}; index++)); do
                    mv -f -- "${pending_temporaries[index]}" "${pending_targets[index]}" || return 1
                done
                return 0
                ;;
            ERROR)
                printf 'stress-uv: privileged broker: %s\n' "$source" >&2
                return 1
                ;;
            *) return 1 ;;
        esac
    done
}

stop_privileged_broker() {
    local acknowledged=0
    local attempt
    local stopped=0
    local type
    local value

    if [[ $BROKER_IN_FD =~ ^[0-9]+$ ]]; then
        if send_broker_request SHUTDOWN &&
            IFS=$'\t' read -r -t 5 -u "$BROKER_OUT_FD" type value 2>/dev/null &&
            [[ $type == BYE && $value == 0 ]]; then
            acknowledged=1
        else
            send_broker_request CANCEL || true
        fi
    fi
    close_broker_fds
    for ((attempt = 0; attempt < 20; attempt++)); do
        broker_wrapper_is_running || break
        sleep 0.1
    done
    if broker_wrapper_is_running; then
        kill -TERM "$BROKER_PID" 2>/dev/null || true
        for ((attempt = 0; attempt < 20; attempt++)); do
            broker_wrapper_is_running || break
            sleep 0.1
        done
    fi
    if broker_wrapper_is_running; then
        kill -KILL "$BROKER_PID" 2>/dev/null || true
        for ((attempt = 0; attempt < 20; attempt++)); do
            broker_wrapper_is_running || break
            sleep 0.1
        done
    fi
    if [[ $BROKER_PID =~ ^[1-9][0-9]*$ ]] && ! broker_wrapper_is_running; then
        stopped=1
        wait "$BROKER_PID" 2>/dev/null || true
    fi
    BROKER_PID=""
    BROKER_STARTTIME=""
    (( acknowledged == 1 && stopped == 1 ))
}

cancel_privileged_broker() {
    local attempt

    trap '' PIPE
    if [[ $BROKER_IN_FD =~ ^[0-9]+$ ]]; then
        if send_broker_request CANCEL; then
            printf 'cancellation sent to privileged broker\n' >> "$RUN_DIR/events.log"
        else
            printf 'privileged broker cancellation pipe unavailable\n' >> "$RUN_DIR/events.log"
        fi
    fi
    for ((attempt = 0; attempt < 10; attempt++)); do
        broker_wrapper_is_running || break
        sleep 0.1
    done
    close_broker_fds
    if broker_wrapper_is_running; then
        kill -TERM "$BROKER_PID" 2>/dev/null || true
    fi
    for ((attempt = 0; attempt < 20; attempt++)); do
        broker_wrapper_is_running || break
        sleep 0.1
    done
    if broker_wrapper_is_running; then
        kill -KILL "$BROKER_PID" 2>/dev/null || true
        for ((attempt = 0; attempt < 20; attempt++)); do
            broker_wrapper_is_running || break
            sleep 0.1
        done
    fi
    if [[ $BROKER_PID =~ ^[1-9][0-9]*$ ]] && ! broker_wrapper_is_running; then
        wait "$BROKER_PID" 2>/dev/null || true
    fi
    BROKER_PID=""
    BROKER_STARTTIME=""
}

broker_send_file() {
    local source=$1
    local file=$2
    local chunk
    local encoded="$BROKER_TMP_DIR/transfer-${source}.b64"

    if ! base64 -- "$file" > "$encoded"; then
        rm -f -- "$encoded"
        return 1
    fi
    printf 'DATA_BEGIN\t%s\n' "$source"
    if [[ -s $encoded ]]; then
        while IFS= read -r chunk; do
            printf 'DATA\t%s\t%s\n' "$source" "$chunk"
        done < "$encoded"
    fi
    printf 'DATA_END\t%s\n' "$source"
    rm -f -- "$encoded"
}

broker_stop_process_group() {
    local pid=$1
    local attempt

    [[ $pid =~ ^[1-9][0-9]*$ ]] || return 0
    kill -TERM -- "-$pid" 2>/dev/null || true
    for ((attempt = 0; attempt < 10; attempt++)); do
        process_is_running "$pid" || break
        sleep 0.1
    done
    kill -KILL -- "-$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
}

broker_stop_process_groups() {
    local pid
    local attempt
    local running

    for pid in "$@"; do
        [[ $pid =~ ^[1-9][0-9]*$ ]] || continue
        kill -TERM -- "-$pid" 2>/dev/null || true
    done
    for ((attempt = 0; attempt < 20; attempt++)); do
        running=0
        for pid in "$@"; do
            [[ $pid =~ ^[1-9][0-9]*$ ]] || continue
            process_is_running "$pid" && running=1
        done
        (( running == 0 )) && break
        sleep 0.1
    done
    for pid in "$@"; do
        [[ $pid =~ ^[1-9][0-9]*$ ]] || continue
        kill -KILL -- "-$pid" 2>/dev/null || true
        wait "$pid" 2>/dev/null || true
    done
}

broker_frequency_has_sample() {
    local file=$1
    local line

    [[ -r $file ]] || return 1
    while IFS= read -r line; do
        [[ $line =~ ^[0-9] ]] && return 0
    done < "$file"
    return 1
}

broker_start_stage_frequency() {
    local stage=$1
    local cpu_set
    local attempt
    local IFS=,

    [[ $stage == benchmark-single-run-* || $stage == benchmark-multi-run-* ]] || return 1
    command_exists turbostat || return 1
    if [[ $stage == benchmark-single-run-* ]]; then
        cpu_set=${CPUS[0]}
    else
        cpu_set=$BENCHMARK_CPU_LIST
    fi
    [[ -n $cpu_set ]] || return 1
    BROKER_STAGE_FREQUENCY_FILE="$BROKER_TMP_DIR/benchmark-frequency-${stage}.tsv"
    BROKER_STAGE_FREQUENCY_ERRORS="$BROKER_TMP_DIR/benchmark-frequency-${stage}.errors"
    : > "$BROKER_STAGE_FREQUENCY_FILE"
    : > "$BROKER_STAGE_FREQUENCY_ERRORS"
    setsid turbostat --quiet --interval "$BENCHMARK_FREQUENCY_INTERVAL" \
        --cpu "$cpu_set" --show 'CPU,Avg_MHz,Busy%,Bzy_MHz' \
        --enable Time_Of_Day_Seconds \
        --out "$BROKER_STAGE_FREQUENCY_FILE" \
        > "$BROKER_STAGE_FREQUENCY_ERRORS" 2>&1 &
    BROKER_STAGE_TURBOSTAT_PID=$!
    [[ $BROKER_STAGE_TURBOSTAT_PID =~ ^[1-9][0-9]*$ ]] || return 1
    for ((attempt = 0; attempt < 30; attempt++)); do
        process_is_running "$BROKER_STAGE_TURBOSTAT_PID" || return 1
        broker_frequency_has_sample "$BROKER_STAGE_FREQUENCY_FILE" && return 0
        sleep 0.1
    done
    broker_stop_process_group "$BROKER_STAGE_TURBOSTAT_PID"
    BROKER_STAGE_TURBOSTAT_PID=""
    return 1
}

broker_stop_stage_frequency() {
    local exit_status
    local watchdog_pid

    [[ ${BROKER_STAGE_TURBOSTAT_PID:-} =~ ^[1-9][0-9]*$ ]] || return 1
    kill -TERM -- "-$BROKER_STAGE_TURBOSTAT_PID" 2>/dev/null || return 1
    (
        sleep 5
        kill -KILL -- "-$BROKER_STAGE_TURBOSTAT_PID" 2>/dev/null || true
    ) &
    watchdog_pid=$!
    if wait "$BROKER_STAGE_TURBOSTAT_PID" 2>/dev/null; then
        exit_status=0
    else
        exit_status=$?
    fi
    kill "$watchdog_pid" 2>/dev/null || true
    wait "$watchdog_pid" 2>/dev/null || true
    BROKER_STAGE_TURBOSTAT_PID=""
    (( exit_status == 0 || exit_status == 143 ))
}

broker_append_stage_frequency() {
    local stage=$1
    local log=$2
    local line

    [[ $stage == benchmark-single-run-* || $stage == benchmark-multi-run-* ]] || return 1
    [[ -s ${BROKER_STAGE_FREQUENCY_FILE:-} && -w $log ]] || return 1
    printf 'STRESS_UV_FREQUENCY_BEGIN\t%s\n' "$stage" >> "$log"
    while IFS= read -r line || [[ -n $line ]]; do
        printf '%s\n' "$line" >> "$log"
    done < "$BROKER_STAGE_FREQUENCY_FILE"
    printf 'STRESS_UV_FREQUENCY_END\t%s\n' "$stage" >> "$log"
}

broker_cleanup() {
    (( ${BROKER_CLEANING_UP:-0} == 0 )) || return
    BROKER_CLEANING_UP=1
    trap - EXIT
    trap '' INT TERM HUP PIPE
    broker_stop_process_groups "${BROKER_CHILD_PID:-}" \
        "${BROKER_STAGE_TURBOSTAT_PID:-}" "${BROKER_TURBOSTAT_PID:-}" \
        "${BROKER_JOURNAL_PID:-}"
    [[ -n ${BROKER_TMP_DIR:-} ]] && rm -rf -- "$BROKER_TMP_DIR"
}

broker_signal() {
    broker_cleanup
    exit 130
}

broker_start_telemetry() {
    : > "$BROKER_TMP_DIR/turbostat.txt"
    : > "$BROKER_TMP_DIR/turbostat-errors.txt"
    : > "$BROKER_TMP_DIR/kernel.log"
    : > "$BROKER_TMP_DIR/kernel-errors.txt"
    if command_exists turbostat; then
        setsid turbostat --quiet --interval "$REFRESH_RATE" --cpu core \
            --show 'CPU,Avg_MHz,Busy%,Bzy_MHz' \
            --enable Time_Of_Day_Seconds \
            --out "$BROKER_TMP_DIR/turbostat.txt" \
            > "$BROKER_TMP_DIR/turbostat-errors.txt" 2>&1 &
        BROKER_TURBOSTAT_PID=$!
    else
        printf 'turbostat is not installed\n' > "$BROKER_TMP_DIR/turbostat-unavailable.txt"
    fi
    if command_exists journalctl; then
        journalctl -k --since "$STARTED_AT" --no-pager -o short-iso \
            > "$BROKER_TMP_DIR/kernel.log" 2> "$BROKER_TMP_DIR/kernel-errors.txt" || true
        setsid journalctl -kf -o short-iso \
            >> "$BROKER_TMP_DIR/kernel.log" 2>> "$BROKER_TMP_DIR/kernel-errors.txt" &
        BROKER_JOURNAL_PID=$!
    else
        printf 'journalctl is not installed\n' > "$BROKER_TMP_DIR/journal-unavailable.txt"
    fi
}

broker_stop_telemetry() {
    broker_stop_process_group "${BROKER_TURBOSTAT_PID:-}"
    broker_stop_process_group "${BROKER_JOURNAL_PID:-}"
    BROKER_TURBOSTAT_PID=""
    BROKER_JOURNAL_PID=""
}

broker_stage_allowed() {
    local requested=$1
    local cpu=$2
    local allowed_cpu
    local selected
    local run

    for selected in "${SELECTED_STAGES[@]}"; do
        if [[ $selected == "$requested" && -z $cpu ]]; then
            return 0
        fi
        if [[ $selected == cpu-core-cycle && $requested == cpu-core-cycle && $cpu =~ ^[0-9]+$ ]]; then
            for allowed_cpu in "${CPUS[@]}"; do
                [[ $allowed_cpu == "$cpu" ]] && return 0
            done
        fi
        if [[ $selected == benchmark ]]; then
            case $requested in
                benchmark-single-warmup|benchmark-multi-warmup) [[ -z $cpu ]] && return 0 ;;
                benchmark-single-run-*|benchmark-multi-run-*)
                    run=${requested##*-}
                    [[ -z $cpu && $run =~ ^[1-9][0-9]*$ && $run -le $BENCHMARK_RUNS ]] && return 0
                    ;;
            esac
        fi
    done
    return 1
}

broker_run_stage() {
    local stage=$1
    local cpu=$2
    local command
    local extra
    local exit_status
    local frequency_required=0
    local frequency_status=0
    local log="$BROKER_TMP_DIR/stage.log"

    broker_stage_allowed "$stage" "$cpu" || {
        printf 'ERROR\tinvalid stage request\n'
        return 125
    }
    build_stage_command "$stage" "$cpu"
    : > "$log"
    if [[ $stage == benchmark-single-run-* || $stage == benchmark-multi-run-* ]]; then
        frequency_required=1
        if ! broker_start_stage_frequency "$stage"; then
            printf 'stress-uv: benchmark frequency collector failed to start\n' >> "$log"
            broker_stop_process_group "${BROKER_STAGE_TURBOSTAT_PID:-}"
            BROKER_STAGE_TURBOSTAT_PID=""
            broker_send_file stage "$log" || return 125
            printf 'DONE\t125\n'
            return
        fi
    fi
    STRESS_UV_STAGE_LABEL=$stage setsid "${STAGE_COMMAND[@]}" > "$log" 2>&1 &
    BROKER_CHILD_PID=$!
    while process_is_running "$BROKER_CHILD_PID"; do
        if ! process_matches_identity "$BROKER_WORKER_PID" "$BROKER_WORKER_STARTTIME"; then
            broker_stop_process_group "$BROKER_CHILD_PID"
            broker_stop_process_group "${BROKER_STAGE_TURBOSTAT_PID:-}"
            BROKER_CHILD_PID=""
            BROKER_STAGE_TURBOSTAT_PID=""
            return 130
        fi
        if IFS=$'\t' read -r -t 0.2 -u "$BROKER_REQUEST_FD" command extra; then
            if [[ $command == CANCEL && -z ${extra:-} ]]; then
                printf 'stress-uv broker: cancellation received\n' >&2
                broker_stop_process_group "$BROKER_CHILD_PID"
                broker_stop_process_group "${BROKER_STAGE_TURBOSTAT_PID:-}"
                BROKER_CHILD_PID=""
                BROKER_STAGE_TURBOSTAT_PID=""
                return 130
            fi
            printf 'ERROR\tunexpected request while stage is running\n'
            broker_stop_process_group "$BROKER_CHILD_PID"
            broker_stop_process_group "${BROKER_STAGE_TURBOSTAT_PID:-}"
            BROKER_CHILD_PID=""
            BROKER_STAGE_TURBOSTAT_PID=""
            return 125
        fi
    done
    if wait "$BROKER_CHILD_PID"; then
        exit_status=0
    else
        exit_status=$?
    fi
    BROKER_CHILD_PID=""
    if (( frequency_required == 1 )); then
        broker_stop_stage_frequency || frequency_status=1
        broker_append_stage_frequency "$stage" "$log" || frequency_status=1
        if (( frequency_status != 0 )); then
            printf 'stress-uv: benchmark frequency collector produced invalid evidence\n' >> "$log"
            exit_status=125
        fi
    fi
    if ! broker_send_file stage "$log"; then
        printf 'ERROR\tstage evidence encoding failed\n'
        return 125
    fi
    printf 'DONE\t%s\n' "$exit_status"
}

broker_collect_telemetry() {
    broker_stop_telemetry
    if [[ -e $BROKER_TMP_DIR/turbostat-unavailable.txt ]]; then
        broker_send_file turbostat-unavailable "$BROKER_TMP_DIR/turbostat-unavailable.txt" || return 125
    else
        broker_send_file turbostat "$BROKER_TMP_DIR/turbostat.txt" || return 125
        broker_send_file turbostat-errors "$BROKER_TMP_DIR/turbostat-errors.txt" || return 125
    fi
    if [[ -e $BROKER_TMP_DIR/journal-unavailable.txt ]]; then
        broker_send_file journal-unavailable "$BROKER_TMP_DIR/journal-unavailable.txt" || return 125
    else
        broker_send_file kernel "$BROKER_TMP_DIR/kernel.log" || return 125
        broker_send_file kernel-errors "$BROKER_TMP_DIR/kernel-errors.txt" || return 125
    fi
    printf 'COLLECTED\t0\n'
}

broker_main() {
    (($# == 19)) || die 'internal broker received invalid arguments'
    MODE=$1
    CPU_DURATION=$2
    CORE_DURATION=$3
    CACHE_DURATION=$4
    VM_DURATION=$5
    MEMORY_PERCENT=$6
    REFRESH_RATE=$7
    CPU_LIST=$8
    BENCHMARK_CPU_LIST=$9
    STARTED_AT=${10}
    BENCHMARK_DURATION=${11}
    BENCHMARK_WARMUP=${12}
    BENCHMARK_RUNS=${13}
    BROKER_WORKER_PID=${14}
    BROKER_WORKER_STARTTIME=${15}
    local worker_uid=${16}
    local request_path=${17}
    STRESSAPPTEST_DURATION=${18}
    MEMTESTER_LOOPS=${19}
    local command
    local stage
    local cpu
    local extra
    local read_status

    validate_duration "$CPU_DURATION"
    validate_duration "$CORE_DURATION"
    validate_duration "$CACHE_DURATION"
    validate_duration "$STRESSAPPTEST_DURATION"
    validate_duration "$VM_DURATION"
    validate_duration "$BENCHMARK_DURATION"
    validate_duration "$BENCHMARK_WARMUP"
    validate_integer_range "$BENCHMARK_RUNS" 1 20 'benchmark runs'
    validate_integer_range "$MEMTESTER_LOOPS" 1 100 'memtester loops'
    validate_integer_range "$MEMORY_PERCENT" 1 95 'memory percent'
    [[ $REFRESH_RATE =~ ^[1-9][0-9]*([.][0-9]+)?$ ]] || die 'invalid broker refresh rate'
    [[ $BROKER_WORKER_PID =~ ^[1-9][0-9]*$ && $BROKER_WORKER_STARTTIME =~ ^[0-9]+$ ]] ||
        die 'invalid broker worker identity'
    [[ $worker_uid =~ ^[0-9]+$ ]] || die 'invalid broker worker owner'
    if [[ $MODE == benchmark ]]; then
        [[ $BENCHMARK_CPU_LIST =~ ^[0-9]+(,[0-9]+)*$ ]] ||
            die 'invalid broker benchmark CPU list'
    fi
    [[ -p $request_path && ! -L $request_path ]] || die 'invalid broker request pipe'
    [[ $(stat -c '%u:%a' -- "$request_path") == "$worker_uid:600" ]] ||
        die 'insecure broker request pipe'
    exec {BROKER_REQUEST_FD}<> "$request_path" || die 'cannot open broker request pipe'
    expand_cpu_list "$CPU_LIST"
    select_stages
    if (( EUID == 0 )); then
        local broker_tmp_parent=/run/stress-uv
        [[ ! -e $broker_tmp_parent || ( -d $broker_tmp_parent && ! -L $broker_tmp_parent ) ]] ||
            die 'invalid broker workspace parent'
        mkdir -p -- "$broker_tmp_parent" || die 'cannot create broker workspace parent'
        chown 0:0 -- "$broker_tmp_parent" || die 'cannot own broker workspace parent'
        chmod 700 -- "$broker_tmp_parent" || die 'cannot protect broker workspace parent'
        [[ $(stat -c '%u:%a' -- "$broker_tmp_parent") == 0:700 ]] ||
            die 'insecure broker workspace parent'
    else
        local broker_tmp_parent=${STRESS_UV_TEST_BROKER_TMP_PARENT:-${TMPDIR:-/tmp}/stress-uv-test-broker}
        mkdir -p -- "$broker_tmp_parent" || die 'cannot create test broker workspace parent'
    fi
    BROKER_TMP_DIR=$(mktemp -d -p "$broker_tmp_parent" stress-uv-broker.XXXXXXXX) ||
        die 'cannot create broker workspace'
    BROKER_CHILD_PID=""
    BROKER_STAGE_TURBOSTAT_PID=""
    BROKER_TURBOSTAT_PID=""
    BROKER_JOURNAL_PID=""
    BROKER_CLEANING_UP=0
    trap broker_cleanup EXIT
    trap broker_signal INT TERM HUP PIPE
    broker_start_telemetry
    printf 'READY\t1\n'

    while :; do
        process_matches_identity "$BROKER_WORKER_PID" "$BROKER_WORKER_STARTTIME" || return 130
        command=""
        stage=""
        cpu=""
        extra=""
        if IFS=$'\t' read -r -t 0.2 -u "$BROKER_REQUEST_FD" command stage cpu extra; then
            read_status=0
        else
            read_status=$?
            (( read_status > 128 )) && continue
            return 125
        fi
        [[ -z ${extra:-} ]] || {
            printf 'ERROR\tinvalid request fields\n'
            continue
        }
        case $command in
            RUN) broker_run_stage "${stage:-}" "${cpu:-}" || return $? ;;
            COLLECT)
                [[ -z ${stage:-}${cpu:-} ]] || { printf 'ERROR\tinvalid collect request\n'; continue; }
                broker_collect_telemetry || { printf 'ERROR\ttelemetry evidence encoding failed\n'; return 125; }
                ;;
            SHUTDOWN)
                [[ -z ${stage:-}${cpu:-} ]] || { printf 'ERROR\tinvalid shutdown request\n'; continue; }
                printf 'BYE\t0\n'
                return 0
                ;;
            CANCEL) return 130 ;;
            *) printf 'ERROR\tunknown request\n' ;;
        esac
    done
}

run_stress_stage() {
    local stage=$1
    local cpu=${2:-}
    local label=$stage
    local log
    local exit_status
    local verdict

    [[ -n $cpu ]] && label="${stage}-cpu-${cpu}"
    log="$RUN_DIR/${label}.log"
    build_stage_command "$stage" "$cpu"
    CURRENT_STAGE=$label
    write_state RUNNING "$label"
    printf '\n[%s] START %s\n' "$(date --iso-8601=seconds)" "$label" | tee -a "$RUN_DIR/events.log"
    printf 'Command:'
    printf ' %q' sudo "${STAGE_COMMAND[@]}"
    printf '\n'

    if ! send_broker_request "RUN"$'\t'"$stage"$'\t'"$cpu"; then
        exit_status=125
    else
        receive_stage_from_broker "$log"
        exit_status=$?
    fi

    if (( exit_status == 0 )) && [[ $label == benchmark-*-run-* ]]; then
        if ! extract_benchmark_frequencies "$log" "$label"; then
            printf 'stress-uv: missing or invalid per-CPU frequency samples\n' >> "$log"
            exit_status=125
        elif ! extract_benchmark_metrics "$log" "$label"; then
            printf 'stress-uv: missing or invalid Mfp-ops/sec metrics\n' >> "$log"
            exit_status=125
        fi
    fi
    verdict=$(stage_verdict_for_exit "$exit_status" "$label" "$log")
    printf '%s\t%s\t%s\n' "$label" "$exit_status" "$verdict" >> "$RUN_DIR/stages.tsv"
    printf '[%s] END %s exit=%s verdict=%s\n' \
        "$(date --iso-8601=seconds)" "$label" "$exit_status" "$verdict" | tee -a "$RUN_DIR/events.log"
    return "$exit_status"
}

run_selected_stages() {
    local stage
    local cpu
    local run

    for stage in "${SELECTED_STAGES[@]}"; do
        if [[ $stage == cpu-core-cycle ]]; then
            for cpu in "${CPUS[@]}"; do
                run_stress_stage "$stage" "$cpu" || return $?
            done
        elif [[ $stage == benchmark ]]; then
            run_stress_stage benchmark-single-warmup || return $?
            for ((run = 1; run <= BENCHMARK_RUNS; run++)); do
                run_stress_stage "benchmark-single-run-${run}" || return $?
            done
            run_stress_stage benchmark-multi-warmup || return $?
            for ((run = 1; run <= BENCHMARK_RUNS; run++)); do
                run_stress_stage "benchmark-multi-run-${run}" || return $?
            done
            if write_benchmark_summary && write_benchmark_frequency_summary; then
                printf 'benchmark-summary\t0\tPASS\n' >> "$RUN_DIR/stages.tsv"
            else
                rm -f -- "$RUN_DIR/benchmark-summary.tsv" \
                    "$RUN_DIR/benchmark-frequency-summary.tsv"
                printf 'benchmark-summary\t125\tERROR\n' >> "$RUN_DIR/stages.tsv"
                return 125
            fi
        else
            run_stress_stage "$stage" || return $?
        fi
    done
}

worker_cleanup() {
    local exit_status=$?

    (( WORKER_CLEANING_UP == 0 )) || return "$exit_status"
    WORKER_CLEANING_UP=1
    trap - EXIT INT TERM HUP
    set +e
    if [[ $LAUNCHER_WATCHER_PID =~ ^[1-9][0-9]*$ ]]; then
        kill -TERM "$LAUNCHER_WATCHER_PID" 2>/dev/null || true
        wait "$LAUNCHER_WATCHER_PID" 2>/dev/null || true
        LAUNCHER_WATCHER_PID=""
    fi
    if (( WORKER_FINISHED == 0 )) && [[ -n $RUN_DIR && -d $RUN_DIR ]]; then
        write_state ABORTED "${CURRENT_STAGE:-interrupted}"
        printf '1\n' > "$RUN_DIR/exit-code"
    fi
    cancel_privileged_broker
    stop_file_telemetry
    if [[ -n $SESSION ]] && command_exists tmux && tmux has-session -t "$SESSION" 2>/dev/null; then
        tmux kill-session -t "$SESSION" 2>/dev/null || true
    fi
    return "$exit_status"
}

worker_signal() {
    exit 130
}

watch_launcher() {
    while process_matches_identity "$LAUNCHER_PID" "$LAUNCHER_STARTTIME"; do
        sleep 0.1
    done
    [[ -e $RUN_DIR/launcher-detached ]] && return
    kill -TERM "$$"
}

worker_main() {
    (($# == 21)) || die 'internal worker received invalid arguments'
    RUN_DIR=$1
    MODE=$2
    CPU_DURATION=$3
    CORE_DURATION=$4
    CACHE_DURATION=$5
    VM_DURATION=$6
    MEMORY_PERCENT=$7
    REFRESH_RATE=$8
    TEMPERATURE_THRESHOLD=$9
    CPU_LIST=${10}
    SESSION=${11}
    STARTED_AT=${12}
    TUI_PANE=${13}
    LAUNCHER_PID=${14}
    LAUNCHER_STARTTIME=${15}
    BENCHMARK_DURATION=${16}
    BENCHMARK_WARMUP=${17}
    BENCHMARK_RUNS=${18}
    STRESSAPPTEST_DURATION=${19}
    MEMTESTER_LOOPS=${20}
    BENCHMARK_CPU_LIST=${21}
    [[ -d $RUN_DIR ]] || die "run directory does not exist: $RUN_DIR"
    validate_duration "$CPU_DURATION"
    validate_duration "$CORE_DURATION"
    validate_duration "$CACHE_DURATION"
    validate_duration "$STRESSAPPTEST_DURATION"
    validate_duration "$VM_DURATION"
    validate_duration "$BENCHMARK_DURATION"
    validate_duration "$BENCHMARK_WARMUP"
    validate_integer_range "$BENCHMARK_RUNS" 1 20 'benchmark runs'
    validate_integer_range "$MEMTESTER_LOOPS" 1 100 'memtester loops'
    validate_integer_range "$MEMORY_PERCENT" 1 95 'memory percent'
    validate_integer_range "$REFRESH_RATE" 1 60 'refresh rate'
    validate_integer_range "$TEMPERATURE_THRESHOLD" 1 120 'temperature threshold'
    if [[ $MODE == benchmark ]]; then
        [[ $BENCHMARK_CPU_LIST =~ ^[0-9]+(,[0-9]+)*$ ]] ||
            die 'invalid worker benchmark CPU list'
    fi
    expand_cpu_list "$CPU_LIST"
    select_stages
    set -e
    trap worker_cleanup EXIT
    trap worker_signal INT TERM HUP
    if [[ $LAUNCHER_PID =~ ^[1-9][0-9]*$ && $LAUNCHER_STARTTIME =~ ^[0-9]+$ ]]; then
        watch_launcher &
        LAUNCHER_WATCHER_PID=$!
    fi

    write_state RUNNING preflight
    start_privileged_broker
    start_file_telemetry
    local harness_status=1
    run_selected_stages || true
    stop_file_telemetry
    if ! collect_broker_telemetry; then
        rm -f -- "$RUN_DIR/kernel.log"
        printf 'privileged telemetry transfer failed\n' > "$RUN_DIR/kernel-errors.txt"
    fi
    if stop_privileged_broker; then
        write_state COMPLETE complete
    else
        printf 'privileged broker shutdown failed\n' >> "$RUN_DIR/broker-errors.txt"
        write_state ABORTED broker-shutdown
    fi
    report_run "$RUN_DIR" > "$RUN_DIR/summary.txt" || true

    if grep -q '^Result: PASS$' "$RUN_DIR/summary.txt"; then
        harness_status=0
    fi
    printf '%s\n' "$harness_status" > "$RUN_DIR/exit-code"
    WORKER_FINISHED=1

    cat "$RUN_DIR/summary.txt"
    if [[ -n $SESSION ]] && command_exists tmux && tmux has-session -t "$SESSION" 2>/dev/null; then
        [[ -n $TUI_PANE ]] && tmux send-keys -t "$TUI_PANE" q 2>/dev/null || true
        sleep 2
        tmux kill-session -t "$SESSION" 2>/dev/null || true
    fi
    return "$harness_status"
}

shell_command() {
    local command_string
    printf -v command_string '%q ' "$@"
    printf '%s\n' "${command_string% }"
}

tmux_setup_failure() {
    local operation=$1

    tmux kill-session -t "$SESSION" 2>/dev/null || true
    write_state ABORTED tmux-setup
    printf '1\n' > "$RUN_DIR/exit-code"
    die "tmux setup failed: $operation"
}

launch_tmux() {
    local tui_command
    local worker_command
    local journal_command
    local window_target
    local worker_arguments
    local launcher_starttime

    launcher_starttime=$(process_starttime "$$") || die 'cannot read launcher process identity'

    tui_command=$(shell_command s-tui --csv --csv-file \
        "$RUN_DIR/telemetry/s-tui.csv" --refresh-rate "$REFRESH_RATE" \
        --t_thresh "$TEMPERATURE_THRESHOLD")
    journal_command=$(shell_command tail -n +1 -F "$RUN_DIR/events.log")

    window_target=$(tmux new-session -d -P -F '#{session_name}:#{window_index}' \
        -s "$SESSION" -x 140 -y 40 "$tui_command") ||
        tmux_setup_failure 'create session'
    TUI_PANE=$(tmux display-message -p -t "$window_target" '#{pane_id}') ||
        tmux_setup_failure 'locate monitoring pane'
    [[ -n $window_target && -n $TUI_PANE ]] || tmux_setup_failure 'locate monitoring pane'
    worker_arguments=(
        "$RUN_DIR" "$MODE" "$CPU_DURATION" "$CORE_DURATION"
        "$CACHE_DURATION" "$VM_DURATION" "$MEMORY_PERCENT" "$REFRESH_RATE"
        "$TEMPERATURE_THRESHOLD" "$CPU_LIST" "$SESSION" "$STARTED_AT" "$TUI_PANE" "$$"
        "$launcher_starttime" "$BENCHMARK_DURATION" "$BENCHMARK_WARMUP" "$BENCHMARK_RUNS"
        "$STRESSAPPTEST_DURATION" "$MEMTESTER_LOOPS" "$BENCHMARK_CPU_LIST"
    )
    worker_command=$(shell_command bash -c '
        session=$1
        shift
        "$@"
        status=$?
        tmux kill-session -t "$session" >/dev/null 2>&1 || true
        exit "$status"
    ' stress-uv-tmux "$SESSION" "$SCRIPT_PATH" __worker "${worker_arguments[@]}")
    WORKER_PANE=$(tmux split-window -P -F '#{pane_id}' -h \
        -t "$window_target" "$worker_command") ||
        tmux_setup_failure 'create worker pane'
    [[ -n $WORKER_PANE ]] || tmux_setup_failure 'create worker pane'
    tmux split-window -v -t "$WORKER_PANE" "$journal_command" ||
        tmux_setup_failure 'create journal pane'
    tmux select-layout -t "$window_target" tiled >/dev/null ||
        tmux_setup_failure 'select layout'
    tmux select-pane -t "$WORKER_PANE" ||
        tmux_setup_failure 'select authentication pane'
    tmux set-option -t "$SESSION" status-right "stress-uv $MODE | $RUN_DIR" >/dev/null ||
        tmux_setup_failure 'set status line'

    printf 'Run directory: %s\n' "$RUN_DIR"
    printf 'tmux session: %s\n' "$SESSION"
    printf 'Detach without stopping: Ctrl-b d\n'
    if ! tmux attach-session -t "$SESSION"; then
        tmux send-keys -t "$WORKER_PANE" C-c 2>/dev/null || true
        sleep 1
        tmux kill-session -t "$SESSION" 2>/dev/null || true
        return 1
    fi

    if tmux has-session -t "$SESSION" 2>/dev/null; then
        : > "$RUN_DIR/launcher-detached"
        printf 'Run continues in tmux session %s\n' "$SESSION"
        printf 'Reattach with: tmux attach-session -t %q\n' "$SESSION"
        return 0
    fi

    [[ -f $RUN_DIR/summary.txt ]] && cat "$RUN_DIR/summary.txt"
    [[ -r $RUN_DIR/exit-code ]] && return "$(< "$RUN_DIR/exit-code")"
    return 1
}

confirm_run() {
    (( ASSUME_YES == 1 )) && return
    [[ -t 0 ]] || die 'refusing to start a stress run without a terminal; pass --yes'

    print_plan
    printf '\nThis workload can expose instability and may crash or reboot the host.\n'
    read -r -p 'Type RUN to continue: ' answer
    [[ $answer == RUN ]] || die 'cancelled'
}

preflight() {
    local stage

    command_exists stress-ng || die 'stress-ng is required'
    command_exists sudo || die 'sudo is required'
    command_exists setsid || die 'setsid is required'
    command_exists base64 || die 'base64 is required'
    for stage in "${SELECTED_STAGES[@]}"; do
        case $stage in
            benchmark)
                command_exists turbostat || die 'turbostat is required for benchmark mode'
                ;;
            memory-stressapptest)
                command_exists stressapptest || die 'stressapptest is required for this mode'
                ;;
            memory-memtester)
                command_exists memtester || die 'memtester is required for this mode'
                ;;
        esac
    done
    if (( NO_TUI == 0 )); then
        command_exists tmux || die 'tmux is required unless --no-tui is used'
        command_exists s-tui || die 's-tui is required unless --no-tui is used'
        [[ -t 0 && -t 1 ]] || die 'interactive mode requires a terminal; use --no-tui'
    fi
}

set_benchmark_cpu_list() {
    local online_cpu_list
    local -a selected_cpus=("${CPUS[@]}")

    [[ $MODE == benchmark ]] || return
    online_cpu_list=$(default_cpu_list)
    expand_cpu_list "$online_cpu_list"
    BENCHMARK_CPU_LIST=$(IFS=,; printf '%s' "${CPUS[*]}")
    CPUS=("${selected_cpus[@]}")
    [[ -n $BENCHMARK_CPU_LIST ]] || die 'online CPU list expands to no CPUs'
}

create_run() {
    local timestamp
    local stress_ng_version

    timestamp=$(date '+%Y%m%d-%H%M%S')
    mkdir -p -- "$OUTPUT_ROOT"
    RUN_DIR=$(readlink -m -- "$OUTPUT_ROOT/${timestamp}-${MODE}")
    [[ ! -e $RUN_DIR ]] || die "run directory already exists: $RUN_DIR"
    mkdir -p -- "$RUN_DIR/telemetry"
    SESSION="stress-uv-${timestamp}-$$"
    STARTED_AT=$(date --iso-8601=seconds)
    : > "$RUN_DIR/stages.tsv"
    : > "$RUN_DIR/events.log"
    : > "$RUN_DIR/broker-errors.txt"
    if [[ $MODE == benchmark ]]; then
        IFS= read -r stress_ng_version < <(stress-ng --version)
        [[ -n $stress_ng_version ]] || die 'stress-ng returned no version string'
        [[ -n $BENCHMARK_CPU_LIST ]] || die 'online CPU list expands to no CPUs'
        printf 'scope\trun\tmetric\tvalue\n' > "$RUN_DIR/benchmark.tsv"
        printf 'scope\trun\tsample\ttime_seconds\tpackage\tcore\tcpu\tavg_mhz\tbusy_percent\tbzy_mhz\n' \
            > "$RUN_DIR/benchmark-frequencies.tsv"
        write_benchmark_cpu_config || die 'failed to capture benchmark CPU frequency configuration'
        {
            printf 'format_version\t2\n'
            printf 'cpu_list\t%s\n' "$CPU_LIST"
            printf 'single_cpu\t%s\n' "${CPUS[0]}"
            printf 'online_cpu_list\t%s\n' "$BENCHMARK_CPU_LIST"
            printf 'stress_ng_version\t%s\n' "$stress_ng_version"
            printf 'benchmark_duration\t%s\n' "$BENCHMARK_DURATION"
            printf 'benchmark_warmup\t%s\n' "$BENCHMARK_WARMUP"
            printf 'benchmark_runs\t%s\n' "$BENCHMARK_RUNS"
        } > "$RUN_DIR/benchmark-context.tsv"
    fi
    write_expected_stages
    write_state RUNNING created
    collect_metadata
}

main() {
    if (($# == 0)); then
        usage
        exit 2
    fi

    case $1 in
        -h|--help)
            usage
            return
            ;;
        --version)
            printf 'stress-uv %s\n' "$VERSION"
            return
            ;;
        report)
            (($# == 2)) || die 'usage: stress-uv report RUN_DIR'
            report_run "$2"
            return
            ;;
        compare)
            (($# == 3)) || die 'usage: stress-uv compare BASELINE_RUN CANDIDATE_RUN'
            compare_benchmarks "$2" "$3"
            return
            ;;
    esac

    MODE=$1
    shift
    parse_options "$@"
    [[ -n $CPU_LIST ]] || CPU_LIST=$(default_cpu_list)
    expand_cpu_list "$CPU_LIST"
    select_stages
    set_benchmark_cpu_list

    if (( DRY_RUN == 1 )); then
        print_plan
        return
    fi

    confirm_run
    preflight
    create_run
    if (( NO_TUI == 1 )); then
        worker_main "$RUN_DIR" "$MODE" "$CPU_DURATION" "$CORE_DURATION" \
            "$CACHE_DURATION" "$VM_DURATION" "$MEMORY_PERCENT" "$REFRESH_RATE" \
            "$TEMPERATURE_THRESHOLD" "$CPU_LIST" "$SESSION" "$STARTED_AT" "" "" "" \
            "$BENCHMARK_DURATION" "$BENCHMARK_WARMUP" "$BENCHMARK_RUNS" \
            "$STRESSAPPTEST_DURATION" "$MEMTESTER_LOOPS" "$BENCHMARK_CPU_LIST"
    else
        launch_tmux
    fi
}

if [[ ${1:-} == __broker ]]; then
    shift
    broker_main "$@"
elif [[ ${1:-} == __worker ]]; then
    shift
    worker_main "$@"
elif [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    main "$@"
fi
